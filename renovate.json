{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["config:recommended"],
    "automergeStrategy": "squash",
    "automergeType": "pr",
    "packageRules": [
        {
            "matchCurrentVersion": "< 1.0.0",
            "separateMinorPatch": true,
            "patch": {
                "groupName": "all non-breaking updates",
                "groupSlug": "non-breaking"
            },
            "automerge": true
        },
        {
            "matchCurrentVersion": ">= 1.0.0",
            "minor": {
                "groupName": "all non-breaking updates",
                "groupSlug": "non-breaking"
            },
            "automerge": true
        },
        {
            "groupName": "npm",
            "matchDatasources": ["npm"],
            "minimumReleaseAge": "3 days"
        },
        {
            "description": "First-party packages are managed by this repository and do not need a third-party release cooldown.",
            "matchDatasources": ["npm"],
            "matchPackageNames": ["/^@swc\\//"],
            "minimumReleaseAge": "0 days"
        },
        {
            "groupName": "cargo",
            "matchDatasources": ["crate"],
            "minimumReleaseAge": "3 days"
        },
        {
            "groupName": "actions",
            "matchManagers": ["github-actions"],
            "minimumReleaseAge": "3 days",
            "automerge": true
        },
        {
            "matchDepTypes": ["devDependencies"],
            "automerge": true
        }
    ],
    "ignorePaths": ["packages/core/e2e/fixtures"]
}
